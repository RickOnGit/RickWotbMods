#!/usr/bin/env bash

source $HOME/RickWotbMods/lib/game.env
source $HOME/RickWotbMods/lib/user.env
source $HOME/RickWotbMods/lib/functions.sh

while true; do
  ans=$(echo -e "$menu" | gum choose --header "Select a category to mod 👇")

  case "$ans" in
    "Tanks")
      if gum confirm "Choose what to do:" --affirmative "Install mods" --negative "Restore original files"; then
        selectorMods "$tanksfile" "$ans"
      else
        selectorOriginal "$tanksfile" "$ans"
      fi
      ;;
    "Sounds")
      selectorMods "$soundsfile" "$ans"
      ;;
    "Quit")
      clear; break
      ;;
  esac
done
